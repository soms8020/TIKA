{
  "name": "tika",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "test": "jest --runInBand",
    "test:components": "jest --runInBand --testPathPattern=components",
    "drizzle": "drizzle-kit",
